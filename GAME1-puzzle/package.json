{
  "name": "game1-puzzle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "15 puzzle app with Capacitor Android support",
  "scripts": {
    "build": "node scripts/build-web-assets.js",
    "start": "npm run build && npx serve www",
    "test": "node --test",
    "harness:check": "node scripts/harness-check.js",
    "harness:audit": "npm audit --omit=dev",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync android",
    "icons:generate": "npx @capacitor/assets generate --android"
  },
  "dependencies": {
    "@capacitor-community/admob": "6.0.0",
    "@capacitor/android": "6.2.0",
    "@capacitor/core": "6.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "6.2.0",
    "esbuild": "^0.28.0",
    "serve": "^14.2.3"
  }
}
